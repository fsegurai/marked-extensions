{
  "name": "@fsegurai/marked-extensions",
  "version": "17.0.0-beta.3",
  "description": "Extensions for Marked.js",
  "type": "module",
  "license": "MIT",
  "author": {
    "name": "Fabián Segura",
    "url": "https://www.fsegurai.com/"
  },
  "keywords": [
    "extensions",
    "javascript",
    "library",
    "markdown",
    "markedjs",
    "marked-extended-accordion",
    "marked-extended-alert",
    "marked-extended-comments",
    "marked-extended-embeds",
    "marked-extended-footnote",
    "marked-extended-kanban",
    "marked-extended-lists",
    "marked-extended-slide",
    "marked-extended-spoiler",
    "marked-extended-tables",
    "marked-extended-tabs",
    "marked-extended-timeline",
    "marked-extended-typographic",
    "parser",
    "syntax",
    "typescript"
  ],
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "prebuild": "bun run clean",
    "build": "bun run build:packages && bun run build:demo && bun run postbuild:demo",
    "postbuild:demo": "cpy ./README.md ./demo && cpy ./LICENSE ./demo",
    "build:packages": "bun run --filter '*' prepare",
    "build:demo": "rollup -c rollup.config.js",
    "build:doppler": "doppler run bun run build",
    "build:packages:doppler": "doppler run bun run build:packages",
    "build:demo:doppler": "doppler run bun run build:demo && bun run postbuild:demo",
    "clean": "bun run clean:packages && bun run clean:demo",
    "clean:packages": "rimraf --glob ./packages/*/dist",
    "clean:demo": "rimraf --glob ./demo/dist ./demo/README.md ./demo/LICENSE",
    "clean:coverage": "rimraf --glob ./coverage",
    "dev": "rollup -w -c rollup.config.js",
    "dev:doppler": "doppler run bun run dev",
    "start": "bun run dev",
    "start:doppler": "bun run dev:doppler",
    "test": "bun run --filter '*' test:package",
    "test:coverage": "bun test --coverage",
    "test:snapshots": "bun test --update-snapshots",
    "test:summary": "bun run ./scripts/test-all-packages.ts --summary",
    "test:packages": "bun run --filter '*' test:coverage",
    "test:packages:snapshots": "bun run --filter '*' test -- --update-snapshots",
    "lint": "bun run lint:packages && bun run lint:demo",
    "lint:check": "eslint . --max-warnings 0",
    "lint:fix": "bun run lint:packages --fix && bun run lint:demo --fix",
    "lint:packages": "eslint ./packages/*/src/**",
    "lint:demo": "eslint ./demo",
    "generate:helpers": "bun packages/.helper/utils/generate-utils.ts",
    "generate:readme": "bun packages/.helper/docs/generate-readme.ts",
    "version:update": "bun packages/.helper/versions/update-packages-versions.ts --write",
    "version:preview": "bun packages/.helper/versions/update-packages-versions.ts --dry-run"
  },
  "dependencies": {
    "@material/web": "^2.4.1",
    "clipboard": "^2.0.11",
    "github-slugger": "^2.0.0",
    "marked": "^17.0.5",
    "marked-highlight": "^2.2.3",
    "prismjs": "^1.30.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-replace": "^6.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@types/jsdom": "^28.0.1",
    "@types/prismjs": "^1.26.6",
    "bun-types": "^1.3.11",
    "cpy-cli": "^7.0.0",
    "dotenv": "^17.3.1",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "jsdom": "^29.0.1",
    "rimraf": "^6.1.3",
    "rollup": "^4.60.0",
    "rollup-plugin-dev": "^2.1.0",
    "semantic-release": "^25.0.3",
    "typescript": "6.0.2",
    "typescript-eslint": "^8.57.2"
  }
}
