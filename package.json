{
  "name": "@fsegurai/marked-extensions",
  "version": "17.0.0-beta.5",
  "description": "Extensions for Marked.js",
  "type": "module",
  "license": "MIT",
  "author": {
    "name": "Fabián Segura",
    "url": "https://www.fsegurai.com/"
  },
  "engines": {
    "node": ">=22",
    "bun": ">=1.3.0",
    "npm": ">=10"
  },
  "keywords": [
    "extensions",
    "javascript",
    "library",
    "markdown",
    "markedjs",
    "accordion",
    "alert",
    "bundle",
    "comments",
    "embeds",
    "footnote",
    "kanban",
    "lists",
    "slide",
    "spoiler",
    "tables",
    "tabs",
    "timeline",
    "typographic",
    "parser",
    "syntax",
    "typescript"
  ],
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "prebuild": "bun run clean",
    "build": "bun run build:packages && bun run postbuild:packages && bun run build:demo && bun run postbuild:demo",
    "postbuild:demo": "cp ./README.md ./demo/README.md && cp ./LICENSE ./demo/LICENSE",
    "postbuild:packages": "find ./packages -maxdepth 1 -type d ! -name '.helper' ! -name 'packages' -exec cp ./LICENSE {} \\;",
    "build:packages": "bun run --filter '*' pkg:build",
    "build:demo": "vite build",
    "build:demo:dev": "vite dev",
    "build:doppler": "doppler run bun run build",
    "build:packages:doppler": "doppler run bun run build:packages && bun run postbuild:packages",
    "build:demo:doppler": "doppler run bun run build:demo && bun run postbuild:demo",
    "clean": "bun run clean:packages && bun run clean:demo",
    "clean:packages": "rimraf --glob ./packages/*/dist && rimraf --glob ./packages/*/LICENSE",
    "clean:demo": "rimraf --glob ./demo/dist ./demo/README.md ./demo/LICENSE",
    "clean:coverage": "rimraf --glob ./coverage",
    "dev": "portless run vite serve",
    "dev:doppler": "doppler run bun run dev",
    "start": "bun run dev",
    "start:doppler": "bun run dev:doppler",
    "test": "bun run --filter '*' pkg:test",
    "test:coverage": "bun test --coverage",
    "test:snapshots": "bun test --update-snapshots",
    "test:summary": "bun run ./scripts/test-all-packages.ts --summary",
    "test:packages": "bun run --filter '*' pkg:test:coverage",
    "test:packages:snapshots": "bun run --filter '*' pkg:test -- --update-snapshots",
    "lint": "bun run lint:packages && bun run lint:demo",
    "lint:check": "eslint . --max-warnings 0",
    "lint:fix": "bun run lint:packages --fix && bun run lint:demo --fix",
    "lint:packages": "eslint ./packages/*/src/**",
    "lint:demo": "eslint ./demo",
    "generate:helpers": "bun packages/.helper/utils/generate-utils.ts",
    "generate:readme": "bun packages/.helper/docs/generate-readme.ts",
    "version:update": "bun packages/.helper/versions/update-packages-versions.ts --write",
    "version:preview": "bun packages/.helper/versions/update-packages-versions.ts --dry-run",
    "version:skip": "bun packages/.helper/versions/update-packages-versions.ts --dry-run --skip '@fsegurai/marked-extended-bundle'"
  },
  "dependencies": {
    "@lezer/markdown": "1.6.3",
    "@material/web": "^2.4.1",
    "clipboard": "^2.0.11",
    "marked": "^17.0.6",
    "marked-highlight": "^2.2.3",
    "prismjs": "^1.30.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^25.5.2",
    "@types/prismjs": "^1.26.6",
    "bun-types": "^1.3.11",
    "eslint": "^10.2.0",
    "glob": "^13.0.6",
    "globals": "^17.4.0",
    "portless": "^0.9.6",
    "jsdom": "^29.0.1",
    "rimraf": "^6.1.3",
    "terser": "^5.46.1",
    "typescript": "6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.7"
  }
}
